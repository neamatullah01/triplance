{
  "info": {
    "name": "Triplance API - Full Collection",
    "description": "Complete automated Postman collection for all Triplance backend APIs. Tokens are auto-saved, IDs are auto-captured from responses.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": ["// Collection-level pre-request: nothing global needed here"]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection-level test: log status for every request",
          "console.log('Response Status:', pm.response.status, '| Time:', pm.response.responseTime + 'ms');"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:5000",  "type": "string" },
    { "key": "accessToken",  "value": "",                       "type": "string" },
    { "key": "refreshToken", "value": "",                       "type": "string" },
    { "key": "userId",       "value": "",                       "type": "string" },
    { "key": "agencyId",     "value": "",                       "type": "string" },
    { "key": "adminToken",   "value": "",                       "type": "string" },
    { "key": "agencyToken",  "value": "",                       "type": "string" },
    { "key": "postId",       "value": "",                       "type": "string" },
    { "key": "packageId",    "value": "",                       "type": "string" },
    { "key": "bookingId",    "value": "",                       "type": "string" },
    { "key": "reviewId",     "value": "",                       "type": "string" },
    { "key": "commentId",    "value": "",                       "type": "string" }
  ],
