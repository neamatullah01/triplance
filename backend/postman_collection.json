          "name": "Register Traveler",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const res = pm.response.json();",
                  "pm.test('Response has success=true', () => pm.expect(res.success).to.be.true);",
                  "if (res.data && res.data.id) pm.environment.set('userId', res.data.id);",
                  "console.log('Registered userId:', pm.environment.get('userId'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Traveler\",\n  \"email\": \"traveler@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"TRAVELER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
